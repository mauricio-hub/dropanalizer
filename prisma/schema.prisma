// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposals       Proposal[]
  products        Product[]
  ctaDestinations CtaDestination[]
  @@map("users")
}

model CtaDestination {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "whatsapp" or "link"
  name      String?  // optional label e.g. "Zapatos", "MercadoPago"
  value     String   // phone number or URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("cta_destinations")
}

model Proposal {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // "service" or "product"
  template    String   @default("producto_nuevo") // "producto_nuevo" or "oferta_limitada"
  status      String   @default("draft") // "draft" or "published"
  tenantId    String   // For multi-tenancy
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buyUrl    String?  // WhatsApp link or external URL for CTA buttons

  versions Version[]
  images   Image[]
  @@map("proposals")
}

model Version {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  version     Int      @default(1)
  content     Json     // Structured content
  isPublished Boolean  @default(false)
  publicUrl   String?  @unique
  generatedAt DateTime? // Timestamp when AI generated this version
  createdAt   DateTime @default(now())

  events Event[]
  @@map("versions")
}

model Event {
  id         String   @id @default(cuid())
  versionId  String
  version    Version  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  type       String   // "view", "click", "time_spent"
  data       Json     // Event data
  createdAt  DateTime @default(now())
  @@map("events")
}

model Image {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  url        String   // Cloudinary secure_url
  publicId   String   // Cloudinary public_id (for deletion)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  @@map("images")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  type        String   @default("service") // "service" or "product"
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("products")
}